<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Gambler.Bot.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Gambler.Bot.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="RiskHighBrush" Color="#C9352B" />
            <SolidColorBrush x:Key="RiskPositiveBrush" Color="#12805C" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#8A8F98" />
            <Style x:Key="MetricCaptionTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource MutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="MetricValueTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
