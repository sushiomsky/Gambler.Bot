<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Gambler.Bot.WinUI.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Gambler.Bot.WinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Login" />
            <TextBlock x:Name="LoginSubtitleText" Foreground="{ThemeResource MutedTextBrush}" Text="Select a site before preparing login." />
        </StackPanel>

        <InfoBar x:Name="LoginInfoBar" Grid.Row="1" IsOpen="True" Severity="Informational" Title="Login preparation" Message="Fields are generated from Core site metadata." />

        <Grid Grid.Row="2" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <CommandBar x:Name="LoginCommandBar" DefaultLabelPosition="Right">
                        <AppBarButton Icon="Accept" Label="Validate" Click="ValidateButton_Click" />
                        <AppBarButton Icon="Play" Label="Use simulation" Click="SimulationButton_Click" />
                        <AppBarButton Icon="Contact" Label="Live login" Click="LiveLoginButton_Click" />
                    </CommandBar>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="Currency for live login" />
                                <ComboBox
                                    x:Name="CurrencyComboBox"
                                    MaxWidth="480"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="Select currency"
                                    SelectionChanged="CurrencyComboBox_SelectionChanged" />
                                <TextBlock
                                    x:Name="CurrencyHintText"
                                    Foreground="{ThemeResource MutedTextBrush}"
                                    Text="Choose the balance/currency the site should load before live betting."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel x:Name="LoginFieldsPanel" Spacing="12" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Capabilities" />
                    <TextBlock x:Name="NormalLoginText" />
                    <TextBlock x:Name="BrowserLoginText" />
                    <TextBlock x:Name="MirrorText" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
