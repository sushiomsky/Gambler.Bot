<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Gambler.Bot.WinUI.Pages.BetHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Gambler.Bot.WinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Bet History" />
                <TextBlock x:Name="HistorySubtitleText" Foreground="{ThemeResource MutedTextBrush}" Text="Recent bets and session outcomes." />
            </StackPanel>
            <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                <AppBarButton Icon="Refresh" Label="Refresh" Click="RefreshButton_Click" />
                <AppBarButton Icon="Download" Label="Export" Click="ExportButton_Click" />
            </CommandBar>
        </Grid>

        <InfoBar x:Name="HistoryInfoBar" Grid.Row="1" IsOpen="True" Severity="Informational" Title="Storage" Message="Reading persisted SQLite bet tables when a GamblerBot.db file is available." />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SearchTextBox"
                Header="Search history"
                PlaceholderText="Site, game, currency, outcome"
                TextChanged="FilterControl_Changed" />
            <ComboBox
                x:Name="OutcomeFilterComboBox"
                Grid.Column="1"
                Header="Outcome"
                SelectionChanged="FilterControl_Changed"
                SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="Win" />
                <ComboBoxItem Content="Loss" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Visible" />
                    <TextBlock x:Name="VisibleRecordsText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Wins / Losses" />
                    <TextBlock x:Name="WinLossText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0 / 0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Win rate" />
                    <TextBlock x:Name="WinRateText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0%" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Wagered" />
                    <TextBlock x:Name="WageredText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="2">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Net profit" />
                    <TextBlock x:Name="NetProfitText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Profit Sparkline" />
                    <TextBlock x:Name="ProfitSparklineText" FontFamily="Consolas" FontSize="28" Text="No data" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="End profit" />
                    <TextBlock x:Name="ChartEndProfitText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Best / Worst" />
                    <TextBlock x:Name="ChartBestWorstText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0 / 0" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Chart wins/losses" />
                    <TextBlock x:Name="ChartWinLossText" Style="{StaticResource SubtitleTextBlockStyle}" Text="0 / 0" />
                </StackPanel>
            </Grid>
        </Border>

        <ListView x:Name="HistoryListView" Grid.Row="5" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:BetHistoryRecord">
                    <Grid Padding="10" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Bind Timestamp}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Site}" />
                        <TextBlock Grid.Column="2" Text="{x:Bind Game}" />
                        <TextBlock Grid.Column="3" Text="{x:Bind Currency}" />
                        <TextBlock Grid.Column="4" Text="{x:Bind Amount}" />
                        <TextBlock Grid.Column="5" Text="{x:Bind Profit}" />
                        <InfoBadge Grid.Column="6" Value="{x:Bind Outcome}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
