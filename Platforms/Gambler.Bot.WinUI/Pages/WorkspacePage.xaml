<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Gambler.Bot.WinUI.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="SubtitleText" Foreground="{ThemeResource MutedTextBrush}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Migration Surface" />
                    <TextBlock x:Name="BodyText" TextWrapping="Wrap" Foreground="{ThemeResource MutedTextBrush}" />
                    <Button HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8A5;" />
                            <TextBlock Text="Open workspace" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Next Adapters" />
                    <CheckBox Content="View model port" IsChecked="True" />
                    <CheckBox Content="Core service bridge" />
                    <CheckBox Content="Native editor control" />
                    <CheckBox Content="Telemetry and alerts" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
