<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Gambler.Bot.WinUI.Pages.RollVerifierPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Gambler.Bot.WinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Roll Verifier" />
            <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Verify provably-fair rolls with Core site algorithms." />
        </StackPanel>

        <InfoBar x:Name="VerifierInfoBar" Grid.Row="1" IsOpen="True" Severity="Informational" Title="Verifier" Message="Choose a site, game, seeds, and nonce." />

        <Grid Grid.Row="2" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="14">
                    <ComboBox x:Name="SiteComboBox" Header="Site" SelectionChanged="SiteComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:SiteSummary">
                                <TextBlock Text="{x:Bind Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox x:Name="GameComboBox" Header="Game" />
                    <TextBox x:Name="ServerSeedTextBox" Header="Server seed" PlaceholderText="Revealed server seed" />
                    <TextBox x:Name="ClientSeedTextBox" Header="Client seed" PlaceholderText="Client seed used for the bet" />
                    <NumberBox x:Name="NonceNumberBox" Header="Nonce" Value="0" Minimum="0" SpinButtonPlacementMode="Inline" />
                    <Button HorizontalAlignment="Left" Click="VerifyButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" />
                            <TextBlock Text="Verify roll" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Result" />
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Site / Game" />
                        <TextBlock x:Name="ResultSiteGameText" Text="-" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="Server seed hash" />
                        <TextBlock x:Name="ServerSeedHashText" FontFamily="Consolas" TextWrapping="Wrap" Text="-" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ResultTypeText" Foreground="{ThemeResource MutedTextBrush}" Text="Verified value" />
                        <TextBlock x:Name="ResultValueText" Style="{StaticResource MetricValueTextBlockStyle}" Text="-" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
